# ============================================================
#  YT-Insight — environment configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# --- Whisper ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda          # cuda | cpu
WHISPER_COMPUTE_TYPE=int8    # int8 | float16 | float32
WHISPER_LANGUAGE=            # Leave empty for auto-detection

# --- LLM Backend (analyzer) ---
# Currently only one backend is implemented: llamacpp-local.
# Future: ollama_local, ollama_cloud, minimax, claude.
LLM_BACKEND=llamacpp_local

# --- llama.cpp (llama-server) ---
# Default: a local llama-server speaking the OpenAI API on :8080
# (i.e. `llama-server -m <model.gguf> --port 8080`).
# Any OpenAI-compatible server works here (Ollama, vLLM, LM Studio…).
LLAMACPP_BASE_URL=http://localhost:8080
LLAMACPP_MODEL=Qwen3.6-35B-A3B-UD-IQ3_S.gguf

# HTTP timeout in seconds (chunk+merge on long videos can take minutes)
LLAMACPP_TIMEOUT_S=600

# Soft cap on prompt tokens. Above this we switch to chunk+merge.
# Must stay well below the server's n_ctx (32k for the default GGUF).
LLAMACPP_MAX_PROMPT_TOKENS=28000

# Number of tokens of overlap between consecutive chunks.
LLAMACPP_CHUNK_OVERLAP_TOKENS=200

LLAMACPP_TEMPERATURE=0.2
LLAMACPP_MAX_TOKENS=4000

# Disable Qwen3 "thinking" mode (recommended for structured JSON output).
# Set to 0 to enable thinking (slower, more verbose).
LLAMACPP_DISABLE_THINKING=1

# --- Paths ---
OUTPUT_DIR=./outputs
CACHE_DIR=./cache
KEEP_AUDIO=false

# --- Pipeline ---
# YT_INSIGHT_STEPS=download,transcribe,analyze
# YT_INSIGHT_FAIL_FAST=1
# YT_INSIGHT_LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# --- Output formats ---
# YT_INSIGHT_OUTPUT_FORMATS=markdown,json
# YT_INSIGHT_INCLUDE_TRANSCRIPT=1
# YT_INSIGHT_INCLUDE_TIMESTAMPS=1
